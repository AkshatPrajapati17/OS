pages = [7,0,1,2,0,3,0,4]
frames=[]
capacity=3
fault = 0

for page in pages:
    if page not in frames:
        fault+=1
        if len(frames)<capacity:
            frames.append(page)
        else:
            frames.pop(0)
            frames.append(page)
    print(frames)
print("No of fault:",fault)
